# ─── Chain selection ─────────────────────────────────────────────────────────
# One process = one chain. "solana" (default) or "evm". Picks the adapter,
# route set, OpenAPI spec, and which vars below are required.
IQ_CHAIN=solana

# ─── Solana (when IQ_CHAIN=solana) ───────────────────────────────────────────
SOLANA_CLUSTER=mainnet-beta
SOLANA_RPC_ENDPOINT=https://api.mainnet-beta.solana.com

# ─── EVM (when IQ_CHAIN=evm) ─────────────────────────────────────────────────
# IQETH_NETWORK=sepolia                       # sepolia | monad | monadTestnet
# IQETH_RPC_ENDPOINT=https://rpc.sepolia.org  # any EVM JSON-RPC URL
# ALCHEMY_API_KEY=                            # optional — batch + higher limits
# ENS_RPC_ENDPOINT=https://eth.llamarpc.com   # mainnet RPC for ENS resolution
# KNOWN_DBROOTS_FILE=./config/known-dbroots.json

# Optional — Helius paid plan enables gTFA (100x faster reads) + batch
# HELIUS_API_KEY=your-key-here
# HELIUS_API_KEYS=key1,key2,key3  # multiple keys for 429 fallback

# Optional — backfill all historical txs on startup (requires Helius paid plan)
# IQ Labs contract first tx: slot 398615411 (Feb 7 2026)
# BACKFILL_FROM_SLOT=398615411

# Optional
# PORT=3000
# MAX_CACHE_SIZE=10GB
