# Solana RPC endpoint
SOLANA_RPC_ENDPOINT=https://api.devnet.solana.com

# Gateway URL (for mint scripts - set to your gateway)
GATEWAY_URL=http://localhost:3000

# Asset signature (for mint scripts - set after uploading)
ASSET_SIG=

# Server port (only if running your own gateway)
PORT=3000

# Base path for URLs (if behind a reverse proxy)
BASE_PATH=

# Default creator address for NFT metadata (optional)
DEFAULT_CREATOR=
