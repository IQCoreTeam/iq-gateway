# Solana cluster: devnet | mainnet-beta | testnet
SOLANA_CLUSTER=mainnet-beta

# Required: Solana RPC endpoint (must match cluster above)
SOLANA_RPC_ENDPOINT=

# Required: Gateway URL (for mint scripts)
GATEWAY_URL=

# Optional: Server port (default 3000)
PORT=3000

# Optional: Base path for URLs (if behind a reverse proxy)
BASE_PATH=

# Optional: Cache directory (default ./cache)
CACHE_DIR=./cache

# Optional: Max cache size - prunes LRU when exceeded (default 10GB)
# Supports: B, KB, MB, GB, TB
MAX_CACHE_SIZE=10GB

# Optional: Helius API key for faster RPC and enhanced endpoints.
# When set, the gateway uses Helius as the primary RPC with:
#   - Higher rate limits (100 burst / 50 refill vs 30/10)
#   - Faster getSignaturesForAddress (critical for /table/index)
#   - Parallel batch transaction fetching for uncached rows
# Get a free key at https://www.helius.dev
# HELIUS_API_KEY=your-helius-api-key-here

# Optional: Override default rate limits (auto-tuned when Helius is enabled)
# RPC_RATE_LIMIT=100
# RPC_REFILL_RATE=50

# For testing scripts only
# KEYPAIR_PATH=/home/youruser/.config/solana/id.json
