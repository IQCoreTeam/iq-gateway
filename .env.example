# Required: Solana RPC endpoint
SOLANA_RPC_ENDPOINT=

# Optional: Gateway URL (enables registry + peer discovery)
GATEWAY_URL=

# Optional: Server port (default 3000)
PORT=3000

# Optional: Base path for URLs (if behind a reverse proxy)
BASE_PATH=

# Optional: Cache directory (default ./cache)
CACHE_DIR=./cache

# Optional: Max cache size - prunes LRU when exceeded (default 10GB)
# Supports: B, KB, MB, GB, TB
MAX_CACHE_SIZE=10GB

# Optional: Keypair for registry operations (register, heartbeat)
# Without this, gateway runs in read-only mode (can still query peers)
# KEYPAIR_PATH=/home/youruser/.config/solana/id.json
